---
import mxImage from "../assets/team/mx.jpeg";
import QLImage from "../assets/team/lq.jpg";
import WuImage from "../assets/team/wu.jpg";

// Add steering member photo imports here
import steering1Image from "../assets/team/steering1.jpg";
import steering2Image from "../assets/team/steering2.jpg";
import steering3Image from "../assets/team/steering3.jpg";
import steering4Image from "../assets/team/steering4.jpg";

const organizers = [
  { name: "Qian Lou", title: "Assistant Professor", affiliation: "University of Central Florida, USA", link: "https://www.qlou.org/", img: QLImage.src },
  { name: "Mengxin Zheng", title: "Assistant Professor", affiliation: "University of Central Florida, USA", link: "https://mxzheng.github.io/", img: mxImage.src },
  { name: "Hongyi Michael Wu", title: "Professor", affiliation: "University of Arizona, USA", link: "https://wu.static.arizona.edu/", img: WuImage.src },
];

const steering = [
  { name: "Steering Member", affiliation: "Affiliation", img: steering1Image.src },
  { name: "Steering Member", affiliation: "Affiliation", img: steering2Image.src },
  { name: "Steering Member", affiliation: "Affiliation", img: steering3Image.src },
  { name: "Steering Member", affiliation: "Affiliation", img: steering4Image.src },
];
---

<section id="organization" class="py-16 md:py-24 bg-white">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-center mb-12 text-primary-800 animate-on-scroll">
        Organizing Committee
      </h2>

      <!-- Organization Team -->
      <div class="mb-12 animate-on-scroll">
        <h3 class="text-xl font-semibold mb-6 text-primary-700 border-b border-primary-200 pb-2">
          Organization Team
        </h3>
        <div class="grid md:grid-cols-2 gap-4">
          {organizers.map((person) => (
            <div class="flex items-center bg-gray-50 p-4 rounded-lg hover:shadow-sm transition-shadow duration-300">
              {person.img && (
                <img src={person.img} alt={person.name} class="w-20 h-20 rounded-full mr-4 object-cover" />
              )}
              <div>
                <h4 class="font-medium">
                  {person.link ? (
                    <a href={person.link} target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline">
                      {person.name}
                    </a>
                  ) : (
                    person.name
                  )}
                </h4>
                {person.title && <p class="text-sm text-gray-500">{person.title}</p>}
                <p class="text-sm text-gray-600">{person.affiliation}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Steering Committee -->
      <div class="animate-on-scroll">
        <h3 class="text-xl font-semibold mb-6 text-primary-700 border-b border-primary-200 pb-2">
          Steering Committee
        </h3>
        <div class="grid md:grid-cols-2 gap-4">
          {steering.map((person) => (
            <div class="flex items-center bg-gray-50 p-4 rounded-lg hover:shadow-sm transition-shadow duration-300">
              <img src={person.img} alt={person.name} class="w-20 h-20 rounded-full mr-4 object-cover" />
              <div>
                <h4 class="font-medium text-gray-800">{person.name}</h4>
                <p class="text-sm text-gray-600">{person.affiliation}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
